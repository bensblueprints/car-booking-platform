{
  "name": "car-booking-platform",
  "private": true,
  "version": "0.1.0",
  "description": "Reusable multi-tenant car booking platform (Turo-style). Backend API + admin dashboard + client frontends.",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev:api": "pnpm --filter @carbooking/api dev",
    "dev:admin": "pnpm --filter @carbooking/admin dev",
    "dev:web": "pnpm --filter bargain-web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "prettier": "^3.2.5"
  }
}
